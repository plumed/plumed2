# this compiler is used for dependencies generation
# if unset, use normal CXX
ifndef CXXDEP
CXXDEP=$(CXX)
CCDEP=$(CC)
endif

ifndef VERBOSE
AT=@
endif

%.o: %.cpp
	@echo "compiling $<"
	@mkdir -p deps
	$(AT)$(CXX) $(CPPFLAGS) $(ADDCPPFLAGS) $(CXXFLAGS) \
	    -MMD -MP -MF deps/$*.d \
	    -DPLUMED_MODULE_DIR=\"$(notdir $(CURDIR))/\" \
	    -c $< -o $@

%.o: %.c
	@echo "compiling $<"
	@mkdir -p deps
	$(AT)$(CC) $(CPPFLAGS) $(ADDCPPFLAGS) $(CFLAGS) \
	    -MMD -MP -MF deps/$*.d \
	    -DPLUMED_MODULE_DIR=\"$(notdir $(CURDIR))/\" \
	    -c $< -o $@

