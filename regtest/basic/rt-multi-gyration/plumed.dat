rgyr1: GYRATION ATOMS=1-6 TYPE=RADIUS
rgyr2: GYRATION ATOMS=7-12 TYPE=RADIUS
rgyr3: GYRATION ATOMS=13-18 TYPE=RADIUS

rgyrv: GYRATION ...
  TYPE=RADIUS
  ATOMS1=1-6
  ATOMS2=7-12
  ATOMS3=13-18
...

PRINT ARG=rgyr1,rgyr2,rgyr3,rgyrv FILE=colvar FMT=%8.4f

sv: SUM ARG=rgyrv PERIODIC=NO
BIASVALUE ARG=sv
